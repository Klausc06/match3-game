      "setTheme",
      "setTimerManager",
      "start",
      "stop",
      "startSession",
      "stopSession",
      "handleGameOver"
    ],
    "RendererAnimationApi": [
      "playSwapAnimation",
      "clearSwapAnimation",
      "playRemoveAnimation",
      "clearRemoveAnimation",
      "playDropAnimation",
      "clearDropAnimation",
      "playShakeAnimation",
      "clearShakeAnimation",
      "clearTransientAnimations"
    ],
    "Board": [
      "setRuleSet",
      "runEndTurnRules",
      "isPlayableCell",
      "setRandomSeed",
      "findMatches",
      "processDestruction",
      "checkPowerUpInteraction",
      "dropTiles",
      "fillEmpty",
      "hasValidMoves",
      "findPossibleMoves",
      "removeSingleCell"
    ]
  },
  "timing_config_keys": [
    "HINT_IDLE_MS",
    "SWAP_DURATION",
    "REMOVE_DURATION",
    "DROP_DURATION_PER_CELL",
    "INVALID_SWAP_DURATION",
